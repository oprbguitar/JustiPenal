{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "justipenal-api\\.vercel\\.app"
        }
      ],
      "destination": "https://justipenal.andesnova.solutions/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "host",
          "value": "justipenal-api\\.vercel\\.app"
        }
      ],
      "destination": "https://justipenal.andesnova.solutions/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/feedback.js": {
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
